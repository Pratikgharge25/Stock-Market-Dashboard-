        <view>
          <datasources>
            <datasource caption='fact_trades_pnl_kpi+ (Stock_Data_Updated_with_KPI_PnL)' name='federated.11d6xdi03ynta01eab3h200jfda6' />
          </datasources>
          <datasource-dependencies datasource='federated.11d6xdi03ynta01eab3h200jfda6'>
            <column caption='reset' datatype='string' name='[Calculation_2041819514259013637]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&apos;reset filters&apos;' />
            </column>
            <column caption='Trade Win Rate' datatype='real' name='[Calculation_4290804577981046792]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([win_flag]) / COUNT([win_flag])' />
            </column>
