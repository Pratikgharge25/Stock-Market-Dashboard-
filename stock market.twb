      <aliases enabled='yes' />
      <column caption='Calculation1' datatype='integer' name='[Calculation_2041819514249351172]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[market_cap]' />
      </column>
      <column caption='reset' datatype='string' name='[Calculation_2041819514259013637]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&apos;reset filters&apos;' />
      </column>
      <column caption='Portfolio Value' datatype='integer' name='[Calculation_4290804577977446403]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[quantity] * [share_price]' />
      </column>
      <column caption='Portfolio Return %' datatype='real' name='[Calculation_4290804577978941444]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_4290804577977446403]) - SUM([initial_value]))&#13;&#10;/ SUM([initial_value]) * 100' />
      </column>
      <column caption='Dividend Yield %' datatype='real' name='[Calculation_4290804577979334661]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([dividend_per_share] / [share_price]) * 100' />
      </column>
      <column caption='Trade P&amp;L' datatype='real' name='[Calculation_4290804577980309510]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sell_price]) - SUM([buy_price])' />
      </column>
      <column caption='Trade Win Rate' datatype='real' name='[Calculation_4290804577981046792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([win_flag]) / COUNT([win_flag])' />
      </column>
      <column caption='Daily Return' datatype='real' name='[Calculation_4290804577981210633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([share_price]) - LOOKUP(SUM([share_price]), -1))&#13;&#10;/ LOOKUP(SUM([share_price]), -1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Volatility' datatype='real' name='[Calculation_4290804577987657738]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='WINDOW_STDEV([Calculation_4290804577981210633])'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sharpe Ratio' datatype='real' name='[Calculation_4290804577989976075]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_4290804577978941444] / [Calculation_4290804577987657738]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Trading Activity Ratio' datatype='real' name='[Calculation_4290804577994555404]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([volume]) / SUM([outstanding_shares])' />
      </column>
      <column caption='Average Daily Volume (ADV)' datatype='real' name='[Calculation_4290804577994629133]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([volume])' />
      </column>
      <column caption='datee' datatype='date' name='[Calculation_4290804578032414736]' role='dimension' type='ordinal'>
